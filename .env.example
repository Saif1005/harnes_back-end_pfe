# Copier en .env : cp .env.example .env puis renseigner HF_TOKEN.
# Le fichier .env est ignoré par Git (voir .gitignore).

HF_TOKEN=
TRAIN_CLEAR_HF_TOKEN=0

# LangSmith — traces pour l’agent recette (LangChain). Clé : Smith → Settings → API Keys.
# Ne pas commiter de vraie clé ; copier ce fichier en .env et renseigner localement.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=sotipapier-production
# Si ton organisation LangSmith est hébergée en UE uniquement, décommente :
# LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
